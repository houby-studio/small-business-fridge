<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      {{ i18n.t('emails.password_reset_heading') }}
    </title>
  </head>
  <body style="font-family: Arial, sans-serif; color: #111827; line-height: 1.5">
    <h2>
      {{ i18n.t('emails.password_reset_heading') }}
    </h2>
    <p>
      {{ i18n.t('emails.password_reset_intro', { app_name: appName }) }}
    </p>
    <p>
      <a href="{{ resetUrl }}">{{ i18n.t('emails.password_reset_action') }}</a>
    </p>
    <p>
      {{ i18n.t('emails.password_reset_note') }}
    </p>
  </body>
</html>
