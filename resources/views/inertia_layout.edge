<!DOCTYPE html>
<html lang="cs" data-theme="dark" class="sbf-app-booting">

  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="sbf-app-name" content="{{ page.props.appName || 'Small Business Fridge' }}" />

    <title inertia>
      {{ page.props.appName || 'Small Business Fridge' }}
    </title>

    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link href="https://fonts.bunny.net/css?family=inter:400,500,600,700&display=swap" rel="stylesheet" />

    @vite(['inertia/css/app.css', 'inertia/app/app.ts', `inertia/pages/${page.component}.vue`])
    @inertiaHead()
  </head>

  <body class="min-h-screen font-sans antialiased" style="background: #09090b; color: #fff;">
    <div
      id="sbf-boot-loader"
      role="status"
      aria-live="polite"
      style="position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center;"
    >

      <div class="fridge-wrap" aria-hidden="true">
        <div class="fridge-body">
          <div class="fridge-bottle">
          </div>
        </div>
        <div class="fridge-door">
        </div>
        <div class="fridge-seam">
        </div>
      </div>
    </div>
    <div id="sbf-app-shell" style="visibility: hidden;">
      @inertia()
    </div>
  </body>

</html>
