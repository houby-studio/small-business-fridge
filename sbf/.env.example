# =============================================================================
# Small Business Fridge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Vars marked [REQUIRED] must be set. [SECRET] vars should be protected.
# [OPTIONAL] vars have sensible defaults or enable optional features.
#
# Docker secrets alternative: instead of a plain value, use the file: identifier
# to read the secret from a file mounted by Docker secrets:
#   APP_KEY=file:/run/secrets/app_key
# =============================================================================

# =============================================================================
# Core
# =============================================================================
NODE_ENV=development          # development | production | test
PORT=3000                     # [REQUIRED] HTTP port
HOST=localhost                 # [REQUIRED] Bind address (use 0.0.0.0 in Docker)
LOG_LEVEL=info                 # trace | debug | info | warn | error | fatal
TZ=UTC                         # [OPTIONAL] Timezone (e.g. Europe/Prague)

# [REQUIRED] [SECRET] 32+ character random string for encryption/signing
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_KEY=

# [OPTIONAL] Public URL of the application (used in email links)
APP_URL=http://localhost:3000

# [OPTIONAL] URL shown in the feedback link in the UI
FEEDBACK_URL=

# [OPTIONAL] Enable Swagger UI at /docs
SWAGGER_ENABLED=false

# =============================================================================
# Session
# =============================================================================
SESSION_DRIVER=cookie          # cookie | memory

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_HOST=127.0.0.1              # [REQUIRED]
DB_PORT=5432                   # [REQUIRED] dev compose: 5433 | production (Docker internal): 5432
DB_USER=sbf                    # [REQUIRED]
DB_DATABASE=sbf                # [REQUIRED]
DB_PASSWORD=sbf                   # [SECRET] Leave empty if no password

# =============================================================================
# Mail (SMTP)
# =============================================================================
SMTP_HOST=127.0.0.1            # [REQUIRED] dev: 127.0.0.1 (Mailpit) | production: your SMTP server
SMTP_PORT=25                 # [REQUIRED] dev: 1025 (Mailpit) | production: 587 (TLS) or 465 (SSL)
SMTP_USERNAME=                 # [OPTIONAL] Leave empty if no auth
SMTP_PASSWORD=                 # [SECRET]   Leave empty if no auth
SMTP_FROM_ADDRESS=noreply@localhost.localdomain  # [REQUIRED]
SMTP_FROM_NAME=Lednice IT      # [REQUIRED]
SMTP_IGNORE_TLS=false          # [OPTIONAL] Set true for plain SMTP without TLS

# =============================================================================
# OIDC / Microsoft Entra ID (all optional — only when OIDC_ENABLED=true)
# =============================================================================
OIDC_ENABLED=false
OIDC_AUTO_REGISTER=false       # Auto-create user account on first OIDC login
LOCAL_LOGIN_DISABLED=false     # Disable username/password login (OIDC-only mode)
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=          # [SECRET]
# OIDC_TENANT_ID=
# OIDC_REDIRECT_URI=http://localhost:3333/auth/oidc/callback

# =============================================================================
# API authentication
# =============================================================================
API_SECRET=                    # [SECRET] [OPTIONAL] Token for API access

# =============================================================================
# Scheduler cron expressions (all optional — Mon-Fri defaults shown)
# =============================================================================
# CRON_DAILY_REPORT=30 16 * * 1-5
# CRON_UNPAID_REMINDER=0 9 * * 1-5
# CRON_PENDING_APPROVAL=0 9 * * 1-5
# UNPAID_REMINDER_MIN_AGE_DAYS=3

# =============================================================================
# OpenAI integration (optional)
# =============================================================================
# OPENAI_API_KEY=              # [SECRET]

# =============================================================================
# ESL — AIMS provider (optional electronic shelf labels)
# =============================================================================
# ESL_AIMS_ENABLED=false
# ESL_AIMS_BASE_URL=
# ESL_AIMS_STORE=
# ESL_AIMS_CRON=
# ESL_AIMS_VERIFY_TLS=true

# =============================================================================
# ESL — JAMES provider (optional electronic shelf labels)
# =============================================================================
# ESL_JAMES_ENABLED=false
# ESL_JAMES_BASE_URL=
# ESL_JAMES_STORE=
# ESL_JAMES_API_KEY=           # [SECRET]
# ESL_JAMES_CRON=
# ESL_JAMES_VERIFY_TLS=true
