#!/bin/sh
set -eu

if [ -z "$(snapctl get daemon)" ]; then
  snapctl set daemon=false

  # `SNAP_SAVE_DATA` is only exposed on Ubuntu Core systems. This avoids
  # relying on `snapctl model`, which is restricted for many regular snaps.
  if [ -n "${SNAP_SAVE_DATA:-}" ] || snapctl system-mode >/dev/null 2>&1; then
    snapctl set daemon=true
  fi
fi
