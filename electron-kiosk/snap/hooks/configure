#!/bin/bash
set -euo pipefail

# Set defaults for all configurable options before consuming them.
# Run `snap get sbf-kiosk` to inspect current values.
# Run `snap set sbf-kiosk key=value` to change them.

# daemon: run as a background system service (true) or launch manually (false)
[ -n "$(snapctl get daemon)" ]          || snapctl set daemon="true"

# url: address of the SBF web server the kiosk will load.
[ -n "$(snapctl get url)" ]             || snapctl set url=""

# allowed-origins: extra origins the kiosk may navigate to (space- or comma-separated)
[ -n "$(snapctl get allowed-origins)" ] || snapctl set allowed-origins=""

# lang: language code passed to Chromium (e.g. cs, en, de)
[ -n "$(snapctl get lang)" ]            || snapctl set lang="en"

# audio-sink: ALSA output device. 'auto' uses the ALSA default.
# For a specific output use the ALSA device string (check with: aplay -l):
#   hw:0,0   — analog / first output
#   hw:0,3   — HDMI (typical on Intel)
#   hw:0,7   — DisplayPort / second HDMI
[ -n "$(snapctl get audio-sink)" ]      || snapctl set audio-sink="auto"

# audio-volume: output volume percentage applied at startup via amixer (0-100).
[ -n "$(snapctl get audio-volume)" ]    || snapctl set audio-volume="100"

daemon=$(snapctl get daemon)
service="${SNAP_INSTANCE_NAME}.daemon"
case "$daemon" in
  true)
    # Enable the service and restart it so changed snap config is applied.
    snapctl start --enable "$service" 2>&1 || true
    snapctl restart "$service" 2>&1 || true
    ;;
  false)
    snapctl stop --disable "$service" 2>&1 || true
    ;;
  *)
    snapctl set daemon="true"
    exit 1
    ;;
esac
