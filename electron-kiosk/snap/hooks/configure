#!/bin/bash
set -euo pipefail

daemon=$(snapctl get daemon)
case "$daemon" in
  true)
    # start the daemon
    if snapctl services "$SNAP_INSTANCE_NAME" | grep -q inactive; then
      snapctl start --enable "$SNAP_INSTANCE_NAME" 2>&1 || true
    fi
    ;;
  false)
    # stop the daemon
    snapctl stop --disable "$SNAP_INSTANCE_NAME" 2>&1 || true
    ;;
  *)
    snapctl set daemon="true"
    exit 1
    ;;
esac

# Set defaults for all configurable options.
# Run `snap get sbf-kiosk` to inspect current values.
# Run `snap set sbf-kiosk key=value` to change them.

# daemon: run as a background system service (true) or launch manually (false)
[ -n "$(snapctl get daemon)" ]          || snapctl set daemon="true"

# url: address of the SBF web server the kiosk will load
[ -n "$(snapctl get url)" ]             || snapctl set url="http://localhost:3000/"

# allowed-origins: extra origins the kiosk may navigate to (space- or comma-separated)
[ -n "$(snapctl get allowed-origins)" ] || snapctl set allowed-origins=""

# lang: language code passed to Chromium (e.g. cs, en, de)
[ -n "$(snapctl get lang)" ]            || snapctl set lang="en"

# pulse-sink: PulseAudio output sink selection.
# 'auto' keeps the system default. Use 'hdmi', 'analog', or an exact sink name
# (check available sinks with: pactl list sinks short) to force a specific output.
# Requires the audio-playback plug to be connected: snap connect sbf-kiosk:audio-playback pulseaudio:audio-playback
[ -n "$(snapctl get pulse-sink)" ]      || snapctl set pulse-sink="auto"

# pulse-volume: output volume percentage applied to the default sink at startup (0-150).
[ -n "$(snapctl get pulse-volume)" ]    || snapctl set pulse-volume="100"

snapctl restart $SNAP_INSTANCE_NAME
