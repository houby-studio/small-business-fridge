#!/bin/bash
# Snap configure hook — runs when the user calls `snap set sbf-kiosk kiosk-url=…`
# Validates kiosk-url before the app tries to use it.
set -e

KIOSK_URL=$(snapctl get kiosk-url 2>/dev/null || true)

if [ -z "$KIOSK_URL" ]; then
  # Key not set yet — that's fine, the app will print guidance on first launch.
  exit 0
fi

# Must be a valid http or https URL
if ! echo "$KIOSK_URL" | grep -qE '^https?://[^[:space:]]+$'; then
  echo "Error: kiosk-url must be a valid http:// or https:// URL" >&2
  exit 1
fi

echo "kiosk-url set to: $KIOSK_URL"
