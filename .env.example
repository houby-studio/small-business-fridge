# =============================================================================
# Small Business Fridge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# For production Docker deployments, place .env next to compose.yaml.
# Docker Compose loads it automatically — no extra steps needed.
#
# For local development, place .env in the project root.
# =============================================================================

# =============================================================================
# Core
# =============================================================================
TZ=UTC                          # optional — e.g. Europe/Prague
APP_NAME=Small Business Fridge  # shown in UI, emails, and browser title
APP_URL=http://localhost:3000   # REQUIRED — public URL used in email links
FEEDBACK_URL=                   # optional — link shown in the UI sidebar
LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal

# REQUIRED — 32+ character random string; generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_KEY=

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_HOST=127.0.0.1   # use "postgres" when running via Docker Compose
DB_PORT=5432
DB_USER=sbf
DB_DATABASE=sbf
DB_PASSWORD=        # REQUIRED — set a strong password

# =============================================================================
# Mail (SMTP)
# =============================================================================
SMTP_HOST=127.0.0.1                         # your SMTP server hostname
SMTP_PORT=587                               # 587 (STARTTLS) or 465 (SSL)
SMTP_USERNAME=                              # leave empty if no auth
SMTP_PASSWORD=                              # leave empty if no auth
SMTP_FROM_ADDRESS=noreply@localhost.localdomain
SMTP_FROM_NAME=Small Business Fridge
SMTP_IGNORE_TLS=false                       # true = plain SMTP without TLS

# =============================================================================
# OIDC / Microsoft Entra ID  (optional — only when OIDC_ENABLED=true)
# =============================================================================
OIDC_ENABLED=false
OIDC_AUTO_REGISTER=false       # auto-create user account on first OIDC login
LOCAL_LOGIN_DISABLED=false     # set true to disable username/password login
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_TENANT_ID=
# OIDC_REDIRECT_URI=https://yourdomain.com/auth/oidc/callback

# =============================================================================
# API authentication  (optional)
# =============================================================================
# API_SECRET=                  # bearer token for REST API access; leave unset to disable

# =============================================================================
# Swagger UI  (optional)
# =============================================================================
SWAGGER_ENABLED=false          # expose API docs at /docs

# =============================================================================
# OpenAI integration  (optional)
# =============================================================================
# OPENAI_API_KEY=

# =============================================================================
# Scheduler cron expressions  (optional — Mon–Fri defaults are built in)
# =============================================================================
# CRON_DAILY_REPORT=30 16 * * 1-5
# CRON_UNPAID_REMINDER=0 9 * * 1-5
# CRON_PENDING_APPROVAL=0 9 * * 1-5
# UNPAID_REMINDER_MIN_AGE_DAYS=3

# =============================================================================
# ESL — AIMS electronic shelf labels  (optional)
# =============================================================================
# ESL_AIMS_ENABLED=false
# ESL_AIMS_BASE_URL=
# ESL_AIMS_STORE=
# ESL_AIMS_CRON=
# ESL_AIMS_VERIFY_TLS=true

# =============================================================================
# ESL — JAMES electronic shelf labels  (optional)
# =============================================================================
# ESL_JAMES_ENABLED=false
# ESL_JAMES_BASE_URL=
# ESL_JAMES_STORE=
# ESL_JAMES_API_KEY=
# ESL_JAMES_CRON=
# ESL_JAMES_VERIFY_TLS=true
