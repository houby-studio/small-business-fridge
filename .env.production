# Production environment defaults — shipped in the Docker image.
# Sensitive values are read from Docker secrets mounted at /run/secrets/.
# If you pass the variable directly in compose `environment:`, process.env
# wins and the file: reference below is ignored (backwards compatible).
APP_KEY=file:/run/secrets/app_key
DB_PASSWORD=file:/run/secrets/db_password
SMTP_PASSWORD=file:/run/secrets/smtp_password
OIDC_CLIENT_SECRET=file:/run/secrets/oidc_client_secret
API_SECRET=file:/run/secrets/api_secret
OPENAI_API_KEY=file:/run/secrets/openai_api_key
ESL_JAMES_API_KEY=file:/run/secrets/esl_james_api_key
