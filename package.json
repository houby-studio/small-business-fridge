{
  "name": "sbf",
  "version": "3.0.0-alpha.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "scheduler": "node ace scheduler:run",
    "test": "node ace test",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend && npm run typecheck:tests",
    "typecheck:backend": "tsc --noEmit",
    "typecheck:frontend": "vue-tsc --noEmit -p tsconfig.frontend.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#helpers/*": "./app/helpers/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^4.2.0",
    "@playwright/test": "^1.58.2",
    "@poppinss/ts-exec": "^1.4.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.18",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint": "^9.26.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/ally": "^6.0.0",
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/cache": "^2.0.1",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/i18n": "^3.0.0",
    "@adonisjs/inertia": "^4.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/mail": "^10.0.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.0",
    "@adonisjs/vite": "^5.1.0",
    "@inertiajs/vue3": "^2.3.15",
    "@primeuix/styled": "^0.7.4",
    "@primeuix/themes": "^2.0.3",
    "@tpointurier/ally-microsoft": "^0.3.0",
    "@vinejs/vine": "^4.3.0",
    "adonis-autoswagger": "^3.73.0",
    "adonisjs-scheduler": "^2.7.0",
    "dotenv": "^17.3.1",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "mongodb": "^7.1.0",
    "pg": "^8.18.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "vue": "^3.5.28"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
